{
    "version": 2,
    "functions": {
        "backend/wsgi.py": {
            "runtime": "@vercel/python",
            "maxLambdaSize": "15mb"
        }
    },
    "routes": [
        {
            "src": "/static/(.*)",
            "dest": "/staticfiles/$1"
        },
        {
            "src": "/(.*\\.(js|css|png|jpg|jpeg|gif|svg|ico|json))",
            "dest": "/$1"
        },
        {
            "src": "/(.*)",
            "dest": "backend/wsgi.py"
        }
    ]
}